# Puerto del servidor API (default: 3001)
PORT=3001

# URL del frontend (default: http://localhost:5173)
CLIENT_URL=http://localhost:5173

# Clave secreta para sesiones (cámbiala en producción)
SESSION_SECRET=aurum-numeros-secret-cambia-esto

# OpenAI API Key (opcional - si no se configura, se usa sistema local)
OPENAI_API_KEY=

# Stripe (opcional - para pagos)
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
